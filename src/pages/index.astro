---
import "../styles/main.css";
import "../styles/tooltips.css";
import { Image } from "astro:assets";
import loading from "../assets/loading.webp";
import avatar from "../assets/avatar-256.webp";
import russia from "../assets/russia-24.webp";
---

<!doctype html>
<html
  lang="ru"
  class="min-h-screen scroll-smooth overflow-x-hidden overflow-y-hidden"
>
  <head>
    <title>Trixlight's Lair</title>
    <meta charset="utf-8" />
    <meta name="keywords" content="Trixlight, Andy Lunev, Андрей Лунев" />
    <meta name="author" content="Trixlight" />
    <meta
      name="description"
      content="Простенькая визитка со ссылками на аккаунты соц.сетей"
    />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="yandex-verification" content="abc9548534bb19e9" />
    <meta property="og:url" content="https://trixlight.github.io/" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Trixlight's Lair" />
    <meta
      property="og:description"
      content="Простенькая визитка со ссылками на аккаунты соц.сетей"
    />
    <meta
      property="og:image"
      content="https://trixlight.github.io/theme/images/og-meta.png"
    />
    <link href="favicon.ico" rel="icon" type="image/x-icon" />
    <link
      rel="preload"
      as="image"
      href="/theme/images/background-image.webp"
      fetchpriority="high"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Chiron+Hei+HK:ital,wght@0,200..900;1,200..900&family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap"
      rel="stylesheet"
    />
  </head>

  <body
    class="flex items-center justify-center min-h-screen phone:p-2 max-phone:bg-[url(/theme/images/background-image.webp)] bg-local bg-center bg-no-repeat bg-cover"
  >
    <div
      id="loading"
      class="fixed flex flex-col w-screen h-screen top-0 left-0 right-0 z-99 items-center justify-center bg-white opacity-100 transition duration-300 ease-in-out pointer-events-none"
    >
      <Image
        src={loading}
        width="225"
        height="185"
        layout="constrained"
        fit="contain"
        alt=""
        fetchpriority="high"
        loading="eager"
      />
      <span
        class="inline-flex font-sans items-center text-zinc-800 font-medium animate-wiggle"
        >Загружаем страничку...</span
      >
    </div>

    <video
      class="max-phone:hidden fixed w-screen h-screen top-0 left-0 right-0 bottom-0 -z-1 object-cover"
      autoplay
      muted
      loop
      id="background-video"
      poster="theme/images/background-image.webp"
    >
      <source src="theme/background.webm" type="video/webm" />
    </video>

    <div class="flex flex-col relative gap-4 p-4 phone:p-8">
      <div class="gradient"></div>
      <header
        class="flex flex-col gap-4 place-items-center text-center shrink-0"
      >
        <figure>
          <Image
            class="size-55 rounded-full"
            src={avatar}
            width="256"
            height="256"
            layout="constrained"
            fit="contain"
            alt=""
            fetchpriority="high"
            loading="eager"
          />
        </figure>
        <div>
          <h1 class="text-zinc-50 font-heading font-semibold text-4xl">
            Trixlight
          </h1>
          <h2 class="text-zinc-200 font-heading font-semibold text-2xl">
            Андрей Лу́нев
          </h2>
        </div>
        <div>
          <a
            class="inline-flex items-center shrink-0 group font-medium text-zinc-200 hover:text-zinc-50 bg-zinc-700/30 hover:bg-zinc-800/30 border border-zinc-700/10 py-2 px-3 rounded-2xl transition duration-150 ease-in-out"
            href="https://yandex.ru/maps/48/orenburg/"
            data-tooltip="Открыть на Яндекс Карте"
            rel="nofollow"
            target="_blank"
          >
            <Image
              class="size-5 mr-2 group-hover:brightness-110 transition duration-150 ease-in-out"
              src={russia}
              width="24"
              height="24"
              layout="constrained"
              fit="contain"
              alt=""
            />Россия, Оренбург</a
          >
        </div>
      </header>

      <div>
        <p class="text-zinc-200 font-light text-center">
          «They told me I could become somebody, <br />so I became a
          disappointment.»
        </p>
        <p class="text-sm text-center">
          <a
            class="text-zinc-200 hover:text-sky-300 transition duration-150 ease-in-out"
            href="https://www.youtube.com/channel/UCMwGHR0BTZuLsmjY_NT5Pwg"
            data-tooltip="Ninomae Ina'nis Ch. hololive-EN           на YouTube"
            target="_blank"
            rel="nofollow">Ninomae Ina'nis</a
          >
        </p>
      </div>

      <div>
        <nav
          class="flex flex-row flex-wrap justify-items-center justify-evenly gap-1 bg-zinc-700/30 border border-zinc-700/10 p-1 rounded-2xl"
        >
          <a
            class="inline-flex items-center shrink-0 group hover:bg-zinc-800/30 border border-transparent hover:border-zinc-700/10 rounded-2xl transition duration-150 ease-in-out"
            href="https://steamcommunity.com/id/trixlight"
            data-tooltip="Steam"
            target="_blank"
          >
            <img
              class="size-14 group-hover:brightness-110 transition duration-150 ease-in-out"
              src="theme/images/steam-64.webp"
              width="64"
              height="64"
              alt="Steam"
            />
          </a>
          <a
            class="inline-flex items-center shrink-0 group hover:bg-zinc-800/30 border border-transparent hover:border-zinc-700/10 rounded-2xl transition duration-150 ease-in-out"
            href="https://itch.io/c/1593166"
            data-tooltip="Itch.io (NSFW)"
            target="_blank"
          >
            <img
              class="size-14 group-hover:brightness-110 transition duration-150 ease-in-out"
              src="theme/images/itch-io-64.webp"
              width="64"
              height="64"
              alt="Itch.io"
            />
          </a>
          <a
            class="inline-flex items-center shrink-0 group hover:bg-zinc-800/30 border border-transparent hover:border-zinc-700/10 rounded-2xl transition duration-150 ease-in-out"
            href="https://www.youtube.com/trixlight"
            data-tooltip="YouTube"
            target="_blank"
          >
            <img
              class="size-14 group-hover:brightness-110 transition duration-150 ease-in-out"
              src="theme/images/youtube-64.webp"
              width="64"
              height="64"
              alt="YouTube"
            />
          </a>
          <a
            class="inline-flex items-center shrink-0 group hover:bg-zinc-800/30 border border-transparent hover:border-zinc-700/10 rounded-2xl transition duration-150 ease-in-out"
            href="https://coub.com/trixlight"
            data-tooltip="Coub"
            target="_blank"
          >
            <img
              class="size-14 group-hover:brightness-110 transition duration-150 ease-in-out"
              src="theme/images/coub-64.webp"
              width="64"
              height="64"
              alt="Coub"
            />
          </a>
          <a
            class="inline-flex items-center shrink-0 group hover:bg-zinc-800/30 border border-transparent hover:border-zinc-700/10 rounded-2xl transition duration-150 ease-in-out"
            href="https://shikimori.io/Trixlight"
            data-tooltip="Список аниме на Шикимори"
            data-tooltip-location="right"
            target="_blank"
          >
            <img
              class="size-14 group-hover:brightness-110 transition duration-150 ease-in-out"
              src="theme/images/shikimori-64.webp"
              width="64"
              height="64"
              alt="Шикимори"
            />
          </a>
        </nav>
      </div>
      <footer class="text-zinc-400 text-xs font-medium text-center">
        <div>
          <a
            class="text-zinc-200 hover:text-sky-300 transition duration-150 ease-in-out"
            href="https://coub.com/view/3aqkb3"
            data-tooltip="Видео на Coub"
            target="_blank"
            rel="nofollow">Видео</a
          >
          на
          <a
            class="text-zinc-200 hover:text-sky-300 transition duration-150 ease-in-out"
            href="https://steamcommunity.com/sharedfiles/filedetails/?id=2943475816"
            data-tooltip="Обои для Wallpaper Engine"
            target="_blank"
            rel="nofollow">фоне</a
          >
          из аниме
          <a
            class="text-zinc-200 hover:text-sky-300 transition duration-150 ease-in-out"
            href="https://shikimori.io/animes/11499-sankarea"
            data-tooltip="Страничка на Шикимори"
            target="_blank"
            rel="nofollow">Sankarea</a
          >, Эпизод 12.
        </div>
        <div>
          Текущий аватар — Vigna из Arknights от
          <a
            class="text-zinc-200 hover:text-sky-300 transition duration-150 ease-in-out"
            href="https://www.pixiv.net/en/artworks/78078147"
            data-tooltip="Оригинал на Pixiv"
            target="_blank"
            rel="nofollow">icepuli</a
          >.
        </div>
        <div>
          Анимация загрузки — Seana из игры
          <a
            class="text-zinc-200 hover:text-sky-300 transition duration-150 ease-in-out"
            href="https://store.steampowered.com/app/400910"
            data-tooltip="Страничка в Steam"
            target="_blank"
            rel="nofollow">Rabi-Ribi</a
          >.
        </div>
        <div>
          Иконка сайта — Retoree из аниме
          <a
            class="text-zinc-200 hover:text-sky-300 transition duration-150 ease-in-out"
            href="https://shikimori.io/animes/27441-show-by-rock"
            data-tooltip="Страничка на Шикимори"
            target="_blank"
            rel="nofollow">Show By Rock!</a
          >
        </div>
      </footer>
    </div>

    <script>
      document.addEventListener("DOMContentLoaded", function () {
        setTimeout(() => {
          document.getElementById("loading")!.style.opacity = "0";
          document
            .getElementsByTagName("html")[0]
            .classList.remove("overflow-y-hidden");
        }, 500);
        setTimeout(() => {
          document.getElementById("loading")!.classList.add("hidden");
        }, 800);
      });
    </script>
  </body>
</html>
